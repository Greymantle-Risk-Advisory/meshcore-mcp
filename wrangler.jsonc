/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "meshcore-mcp",
	// CHANGE ME before deploying — your Cloudflare Account ID (Dashboard >
	// Workers & Pages overview, right sidebar; or `wrangler whoami`). Not
	// sensitive, safe to commit — only the deploy API token is a secret,
	// and that lives in the CLOUDFLARE_API_TOKEN GitHub Actions secret,
	// never in this file.
	"account_id": "CHANGEME_CLOUDFLARE_ACCOUNT_ID",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-10",
	"compatibility_flags": ["nodejs_compat"],
	"migrations": [
		{
			"new_sqlite_classes": ["MeshcoreMCP"],
			"tag": "v1",
		},
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "MeshcoreMCP",
				"name": "MCP_OBJECT",
			},
		],
	},
	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,
	// Per-IP request cap on /mcp — protects the configured CoreScope
	// instance (CORESCOPE_BASE_URL, someone else's server) from being
	// hammered through this public, authless proxy. 60 req/min/IP is
	// generous for normal tool use.
	"ratelimits": [
		{
			"name": "RATE_LIMITER",
			"namespace_id": "1001",
			"simple": {
				"limit": 60,
				"period": 60,
			},
		},
	],
	// CHANGE ME before deploying — the CoreScope MeshCore analyzer instance
	// this server proxies. No default is baked in so a fresh deploy doesn't
	// silently start sending traffic to someone else's mesh. Not a secret
	// (it's a public instance URL), so a plain var is fine — no need for
	// `wrangler secret put`.
	"vars": {
		"CORESCOPE_BASE_URL": "https://changeme.invalid",
	},
	/**
	 * Smart Placement
	 * https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
	 */
	// "placement": {  "mode": "smart" }
	/**
	 * Bindings
	 * Bindings allow your Worker to interact with resources on the Cloudflare Developer Platform, including
	 * databases, object storage, AI inference, real-time communication and more.
	 * https://developers.cloudflare.com/workers/runtime-apis/bindings/
	 */
	/**
	 * Static Assets
	 * https://developers.cloudflare.com/workers/static-assets/binding/
	 */
	// "assets": {  "directory": "./public/",  "binding": "ASSETS" }
	/**
	 * Service Bindings (communicate between multiple Workers)
	 * https://developers.cloudflare.com/workers/wrangler/configuration/#service-bindings
	 */
	// "services": [  {   "binding": "MY_SERVICE",   "service": "my-service"  } ]
}
